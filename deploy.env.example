APP_PORT=3000

# Supabase/Postgres connection string used by the app and migrations.
# Use the connection string from Supabase Project Settings > Database.
DATABASE_URL=postgresql://postgres:replace-with-your-password@replace-with-your-supabase-host:5432/postgres?sslmode=require

# Only needed when using docker-compose.local-db.yml instead of Supabase.
POSTGRES_DB=survey_form
POSTGRES_USER=survey
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Canonical public URL. Used by Better Auth and backend security checks.
APP_ORIGIN=https://survey.example.com
BETTER_AUTH_URL=https://survey.example.com

# Optional comma-separated list for trusted cross-origin API callers.
# Leave empty for same-origin only.
CORS_ALLOWED_ORIGINS=

BETTER_AUTH_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-cron-secret
